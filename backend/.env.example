# AEP backend configuration (copy to .env). All values shown are safe local defaults.
# For production settings see infra/.env.prod.example

# --- App ---
AEP_ENV=local                 # local | test | production
AEP_LOG_LEVEL=INFO
AEP_LOG_JSON=false            # true => structured JSON logs (use in production)

# --- Database ---
# Leave AEP_DATABASE_URL unset to use the offline SQLite fallback (zero infra).
# For Postgres+pgvector (docker-compose default):
# AEP_DATABASE_URL=postgresql+psycopg://aep:aep@localhost:5432/aep
AEP_DATABASE_URL=

# --- AI providers (offline-first) ---
AEP_OLLAMA_BASE_URL=http://localhost:11434
# Optional cloud providers are OFF by default (feature-flagged, added in Phase 2+).
AEP_ENABLE_CLOUD_PROVIDERS=false

# --- Security (DISABLED by default for local/offline dev; enable in production) ---
# When AEP_API_AUTH_ENABLED=false (default), all endpoints are open — no API key needed.
# When true: POST /admin/api-keys (with X-Admin-Secret) bootstraps the first key.
AEP_API_AUTH_ENABLED=false
# AEP_ADMIN_SECRET=<strong-random-secret>   # required when API_AUTH_ENABLED=true
# AEP_RATE_LIMIT_PER_MINUTE=1000            # sliding-window per API key or IP

# --- Telemetry (opt-in; completely no-op when unset; never blocks offline operation) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
AEP_SERVICE_NAME=aep-backend
